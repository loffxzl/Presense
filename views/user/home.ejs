<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Presense | Luxury & Middle Eastern Fragrances</title>
    
    <!-- BRAND FAVICON -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='25' fill='%231A1A1A'/><text x='50%' y='68%' font-family='Georgia, serif' font-size='55' font-weight='bold' fill='%23D4AF37' text-anchor='middle'>P</text></svg>">

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        scentCream: '#FDFBF7',
                        scentAmber: '#D4AF37',
                        scentCharcoal: '#1A1A1A',
                        scentEarth: '#705335'
                    },
                    keyframes: {
                        fadeInUp: {
                            '0%': { opacity: '0', transform: 'translateY(25px)' },
                            '100%': { opacity: '1', transform: 'translateY(0)' }
                        },
                        fadeIn: {
                            '0%': { opacity: '0' },
                            '100%': { opacity: '1' }
                        }
                    },
                    animation: {
                        fadeInUp: 'fadeInUp 1s cubic-bezier(0.215, 0.610, 0.355, 1) forwards',
                        fadeInUpDelayed: 'fadeInUp 1.4s cubic-bezier(0.215, 0.610, 0.355, 1) forwards',
                        fadeIn: 'fadeIn 1.5s ease-out forwards'
                    }
                }
            }
        }
    </script>
    <style>
        .animate-init { opacity: 0; }
        .shuffle-card {
            transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1), opacity 0.8s ease, z-index 0.8s step-end;
        }
    </style>
</head>
<body class="bg-scentCream text-scentCharcoal font-sans antialiased overflow-x-hidden">

