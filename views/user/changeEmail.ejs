<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Presense</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        :root { --cream: #FDFBF7; --amber: #D4AF37; --charcoal: #1A1A1A; }
        .bg-scentCream { background-color: var(--cream); }
        .bg-scentCharcoal { background-color: var(--charcoal); }
        .text-scentAmber { color: var(--amber); }
        .font-serif { font-family: Georgia, Cambria, "Times New Roman", Times, serif; }
    </style>
</head>
<body class="bg-scentCream min-h-screen flex items-center justify-center p-6">
    <div class="w-full max-w-md bg-white p-8 rounded-2xl shadow-xl border border-gray-100">
        <div class="text-center mb-8">
            <a href="/" class="text-3xl font-serif font-bold text-gray-900 tracking-widest uppercase">Presense</a>
            <p class="text-gray-500 text-sm mt-2">Enter your new email address.</p>
        </div>

        <% if (error) { %>
            <div class="bg-red-50 border border-red-200 text-red-600 text-sm px-4 py-3 rounded-lg mb-4">
                <%= error %>
            </div>
        <% } %>

        <form action="/profile/change-email" method="POST" class="space-y-5" novalidate>
            <div>
                <label class="block text-xs font-semibold text-gray-600 uppercase mb-2">New Email Address</label>
                <input type="email" name="newEmail" required
                       placeholder="new@example.com"
                       class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none transition text-sm">
            </div>
            <button type="submit"
                    class="w-full text-white py-3 rounded-lg font-semibold transition duration-300"
                    style="background-color:var(--charcoal);"
                    onmouseover="this.style.backgroundColor='var(--amber)'"
                    onmouseout="this.style.backgroundColor='var(--charcoal)'">
                Send Verification Code
            </button>
        </form>

        <p class="text-center text-sm text-gray-500 mt-6">
            <a href="/profile" class="text-scentAmber font-semibold hover:underline">Back to Profile</a>
        </p>
    </div>
</body>
</html>