<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Presense</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        :root {
            --cream: #FDFBF7;
            --amber: #D4AF37;
            --charcoal: #1A1A1A;
        }
        .bg-scentCream    { background-color: var(--cream); }
        .bg-scentCharcoal { background-color: var(--charcoal); }
        .text-scentAmber  { color: var(--amber); }
        .hover\:bg-scentAmber:hover { background-color: var(--amber); }
        .font-serif { font-family: Georgia, Cambria, "Times New Roman", Times, serif; }
    </style>
</head>
<body class="bg-scentCream min-h-screen flex items-center justify-center p-6">

    <div class="w-full max-w-md bg-white p-8 rounded-2xl shadow-xl border border-gray-100">
        <div class="text-center mb-8">
            <a href="/" class="text-3xl font-serif font-bold text-gray-900 tracking-widest uppercase">Presense</a>
            <p class="text-gray-500 text-sm mt-2">Enter your email to reset your password.</p>
        </div>

        <% if (error) { %>
            <div class="bg-red-50 border border-red-200 text-red-600 text-sm px-4 py-3 rounded-lg mb-4">
                <%= error %>
            </div>
        <% } %>

        <% if (success) { %>
            <div class="bg-green-50 border border-green-200 text-green-700 text-sm px-4 py-3 rounded-lg mb-4">
                <%= success %>
            </div>
        <% } %>

        <% if (!success) { %>
            <form action="/auth/forgot-password" method="POST" class="space-y-5" id="forgotForm" novalidate>
                <div>
                    <label class="block text-xs font-semibold text-gray-600 uppercase mb-2">Email Address</label>
                    <input type="email" name="email" id="email" required
                           placeholder="you@example.com"
                           class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none transition text-sm">
                    <p class="text-red-500 text-xs mt-1 hidden" id="email-error"></p>
                </div>

                <button type="submit"
                        class="w-full bg-scentCharcoal text-white py-3 rounded-lg font-semibold hover:bg-scentAmber transition duration-300">
                    Send Reset Link
                </button>
            </form>
        <% } %>

        <p class="text-center text-sm text-gray-500 mt-6">
            Remember your password? <a href="/auth/login" class="text-scentAmber font-semibold hover:underline">Log in</a>
        </p>
    </div>

    <script>
        document.getElementById('forgotForm')?.addEventListener('submit', (e) => {
            const email = document.getElementById('email');
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(email.value)) {
                document.getElementById('email-error').textContent = 'Please enter a valid email';
                document.getElementById('email-error').classList.remove('hidden');
                e.preventDefault();
            } else {
                document.getElementById('email-error').classList.add('hidden');
            }
        });
    </script>

</body>
</html>