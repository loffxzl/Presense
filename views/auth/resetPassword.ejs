<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Presense</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        :root {
            --cream: #FDFBF7;
            --amber: #D4AF37;
            --charcoal: #1A1A1A;
        }
        .bg-scentCream    { background-color: var(--cream); }
        .bg-scentCharcoal { background-color: var(--charcoal); }
        .text-scentAmber  { color: var(--amber); }
        .hover\:bg-scentAmber:hover { background-color: var(--amber); }
        .font-serif { font-family: Georgia, Cambria, "Times New Roman", Times, serif; }
        .input-error { border-color: #ef4444 !important; }
    </style>
</head>
<body class="bg-scentCream min-h-screen flex items-center justify-center p-6">

    <div class="w-full max-w-md bg-white p-8 rounded-2xl shadow-xl border border-gray-100">
        <div class="text-center mb-8">
            <a href="/" class="text-3xl font-serif font-bold text-gray-900 tracking-widest uppercase">Presense</a>
            <p class="text-gray-500 text-sm mt-2">Choose a new password.</p>
        </div>

        <% if (error) { %>
            <div class="bg-red-50 border border-red-200 text-red-600 text-sm px-4 py-3 rounded-lg mb-4">
                <%= error %>
            </div>
        <% } %>

        <% if (typeof success !== 'undefined' && success) { %>
            <div class="bg-green-50 border border-green-200 text-green-700 text-sm px-4 py-3 rounded-lg mb-4">
                <%= success %>
            </div>
            <div class="text-center mt-4">
                <a href="/auth/login" class="text-scentAmber font-semibold hover:underline text-sm">Back to Login</a>
            </div>
        <% } else { %>
            <form action="/auth/reset-password/<%= token %>" method="POST" class="space-y-5" id="resetForm" novalidate>

                <div>
                    <label class="block text-xs font-semibold text-gray-600 uppercase mb-2">New Password</label>
                    <div class="relative">
                        <input type="password" name="newPassword" id="newPassword" required
                               placeholder="Min 8 characters"
                               class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none transition text-sm">
                        <button type="button" onclick="togglePass('newPassword')"
                                class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                            <svg style="width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:1.75;" viewBox="0 0 24 24">
                                <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7Z"/><circle cx="12" cy="12" r="3"/>
                            </svg>
                        </button>
                    </div>
                    <p class="text-red-500 text-xs mt-1 hidden" id="new-error"></p>
                </div>

                <div>
                    <label class="block text-xs font-semibold text-gray-600 uppercase mb-2">Confirm New Password</label>
                    <div class="relative">
                        <input type="password" name="confirmNewPassword" id="confirmNewPassword" required
                               placeholder="Repeat new password"
                               class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none transition text-sm">
                        <button type="button" onclick="togglePass('confirmNewPassword')"
                                class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                            <svg style="width:18px;height:18px;stroke:currentColor;fill:none;stroke-width:1.75;" viewBox="0 0 24 24">
                                <path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7Z"/><circle cx="12" cy="12" r="3"/>
                            </svg>
                        </button>
                    </div>
                    <p class="text-red-500 text-xs mt-1 hidden" id="confirm-error"></p>
                </div>

                <button type="submit"
                        class="w-full bg-scentCharcoal text-white py-3 rounded-lg font-semibold hover:bg-scentAmber transition duration-300">
                    Reset Password
                </button>
            </form>
        <% } %>

        <p class="text-center text-sm text-gray-500 mt-6">
            <a href="/auth/login" class="text-scentAmber font-semibold hover:underline">Back to Login</a>
        </p>
    </div>

    <script>
        function togglePass(id) {
            const input = document.getElementById(id);
            input.type = input.type === 'password' ? 'text' : 'password';
        }

        document.getElementById('resetForm')?.addEventListener('submit', (e) => {
            let valid = true;
            const newPass = document.getElementById('newPassword');
            const confirm = document.getElementById('confirmNewPassword');

            if (newPass.value.length < 8) {
                document.getElementById('new-error').textContent = 'Password must be at least 8 characters';
                document.getElementById('new-error').classList.remove('hidden');
                newPass.classList.add('input-error');
                valid = false;
            } else {
                document.getElementById('new-error').classList.add('hidden');
                newPass.classList.remove('input-error');
            }

            if (confirm.value !== newPass.value) {
                document.getElementById('confirm-error').textContent = 'Passwords do not match';
                document.getElementById('confirm-error').classList.remove('hidden');
                confirm.classList.add('input-error');
                valid = false;
            } else {
                document.getElementById('confirm-error').classList.add('hidden');
                confirm.classList.remove('input-error');
            }

            if (!valid) e.preventDefault();
        });
    </script>

</body>
</html>