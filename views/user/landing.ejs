    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='25' fill='%231A1A1A'/><text x='50%' y='68%' font-family='Georgia, serif' font-size='55' font-weight='bold' fill='%23D4AF37' text-anchor='middle'>P</text></svg>">

    <!-- ✅ CSP-safe: cdnjs Tailwind v2 (replaces blocked cdn.tailwindcss.com) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css">

    <style>
        /* ─── Brand Design Tokens ─────────────────────────────── */
        :root {
            --cream:    #FDFBF7;
            --amber:    #D4AF37;
            --charcoal: #1A1A1A;
            --earth:    #705335;
        }

        /* ─── Custom colour utilities (replaces Tailwind config) ─ */
        .bg-scentCream    { background-color: var(--cream); }
        .bg-scentAmber    { background-color: var(--amber); }
        .bg-scentCharcoal { background-color: var(--charcoal); }
        .bg-scentEarth    { background-color: var(--earth); }

        .text-scentAmber    { color: var(--amber); }
        .text-scentCharcoal { color: var(--charcoal); }
        .text-scentEarth    { color: var(--earth); }

        .border-scentAmber    { border-color: var(--amber); }
        .border-scentCharcoal { border-color: var(--charcoal); }

        .hover\:bg-scentAmber:hover    { background-color: var(--amber); }
        .hover\:bg-scentCharcoal:hover { background-color: var(--charcoal); }
        .hover\:bg-scentEarth:hover    { background-color: var(--earth); }
        .hover\:text-scentAmber:hover  { color: var(--amber); }
        .hover\:text-scentEarth:hover  { color: var(--earth); }
        .hover\:border-scentAmber:hover { border-color: var(--amber); }

        /* ─── Keyframe Animations ─────────────────────────────── */
        @keyframes fadeInUp {
            0%   { opacity: 0; transform: translateY(25px); }
            100% { opacity: 1; transform: translateY(0); }
        }
        @keyframes fadeIn {
            0%   { opacity: 0; }
            100% { opacity: 1; }
        }

        .animate-fadeInUp {
            animation: fadeInUp 1s cubic-bezier(0.215, 0.610, 0.355, 1) forwards;
        }
        .animate-fadeInUpDelayed {
            animation: fadeInUp 1.4s cubic-bezier(0.215, 0.610, 0.355, 1) forwards;
        }
        .animate-fadeIn {
            animation: fadeIn 1.5s ease-out forwards;
        }

        /* ─── Misc helpers ────────────────────────────────────── */
        .animate-init { opacity: 0; }

        .shuffle-card {
            transition: transform 0.8s cubic-bezier(0.25, 1, 0.5, 1),
                        opacity 0.8s ease,
                        z-index 0.8s step-end;
        }

        /* Tailwind v2 doesn't have backdrop-filter utilities — polyfill */
        .backdrop-blur-md {
            -webkit-backdrop-filter: blur(12px);
            backdrop-filter: blur(12px);
        }

        /* mix-blend-color-dodge (not in v2) */
        .mix-blend-color-dodge { mix-blend-mode: color-dodge; }
        .mix-blend-luminosity  { mix-blend-mode: luminosity; }

        /* Tailwind v2 lacks some font-serif in JIT — ensure it works */
        .font-serif { font-family: Georgia, Cambria, "Times New Roman", Times, serif; }

        /* Pointer-events none helper */
        .pointer-events-none { pointer-events: none; }

        /* active:scale-98 not in v2 */
        .active\:scale-98:active { transform: scale(0.98); }

        /* group-hover:scale-102 shim */
        .group:hover .group-hover\:scale-102 { transform: scale(1.02); }

        /* duration helpers not in v2 */
        .duration-\[4000ms\] { transition-duration: 4000ms; }
        .duration-\[3000ms\] { transition-duration: 3000ms; }

        /* z helpers */
        .z-5 { z-index: 5; }
    </style>
</head>
