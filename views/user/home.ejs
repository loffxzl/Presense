                    <div class="shuffle-card absolute inset-0 w-full h-full rounded-xl overflow-hidden shadow-2xl border border-white/10 bg-stone-900"
                         style="transform: translate(0px, 0px) scale(1) rotate(0deg); z-index: 50; opacity: 1;">
