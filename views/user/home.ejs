                         style="transform: translate(-32px, 32px) scale(0.84) rotate(-4deg); z-index: 10; opacity: 0.35;">
                        <img src="https://images.unsplash.com/photo-1547887537-6158d64c35b3?q=80&w=800&auto=format&fit=crop" alt="Parisian Rose" class="w-full h-full object-cover pointer-events-none">
