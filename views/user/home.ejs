                         style="transform: translate(32px, -32px) scale(0.92) rotate(4deg); z-index: 30; opacity: 0.75;">
                        <img src="https://images.unsplash.com/photo-1523293182086-7651a899d37f?q=80&w=800&auto=format&fit=crop" alt="Intense Scent" class="w-full h-full object-cover pointer-events-none">
