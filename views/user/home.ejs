                <a href="/" class="text-sm font-medium text-scentCharcoal hover:text-scentAmber transition-colors duration-300">Home</a>
                <a href="/products" class="text-sm font-medium text-scentCharcoal hover:text-scentAmber transition-colors duration-300">Products</a>
