<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account | Presense</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        :root {
            --cream:    #FDFBF7;
            --amber:    #D4AF37;
            --charcoal: #1A1A1A;
        }
        .bg-scentCream    { background-color: var(--cream); }
        .bg-scentCharcoal { background-color: var(--charcoal); }
        .text-scentAmber  { color: var(--amber); }
        .hover\:bg-scentAmber:hover { background-color: var(--amber); }
        .font-serif { font-family: Georgia, Cambria, "Times New Roman", Times, serif; }

        .input-error { border-color: #ef4444 !important; }
        .input-success { border-color: #22c55e !important; }

        .strength-bar {
            height: 4px;
            border-radius: 2px;
            transition: all 0.3s ease;
        }
    </style>
</head>
<body class="bg-scentCream min-h-screen flex items-center justify-center p-6">

    <div class="w-full max-w-md bg-white p-8 rounded-2xl shadow-xl border border-gray-100">
        <div class="text-center mb-8">
            <a href="/" class="text-3xl font-serif font-bold text-gray-900 tracking-widest uppercase">Presense</a>
            <p class="text-gray-500 text-sm mt-2">Begin your olfactory journey.</p>
        </div>

        <% if (error) { %>
            <div class="bg-red-50 border border-red-200 text-red-600 text-sm px-4 py-3 rounded-lg mb-4">
                <%= error %>
            </div>
        <% } %>

        <form action="/auth/signup" method="POST" class="space-y-4" id="signupForm" novalidate>

            <!-- Full Name -->
            <div>
                <label class="block text-xs font-semibold text-gray-600 uppercase mb-2">Full Name</label>
                <input type="text" name="fullname" id="fullname" required
                       class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none transition"
                       placeholder="John Doe">
                <p class="text-red-500 text-xs mt-1 hidden" id="fullname-error"></p>
            </div>

            <!-- Email -->
            <div>
                <label class="block text-xs font-semibold text-gray-600 uppercase mb-2">Email Address</label>
                <input type="email" name="email" id="email" required
                       class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none transition"
                       placeholder="you@example.com">
                <p class="text-red-500 text-xs mt-1 hidden" id="email-error"></p>
            </div>

            <!-- Password -->
            <div>
                <label class="block text-xs font-semibold text-gray-600 uppercase mb-2">Password</label>
                <input type="password" name="password" id="password" required
                       class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none transition"
                       placeholder="Min 8 characters">
                <p class="text-red-500 text-xs mt-1 hidden" id="password-error"></p>

                <!-- Password strength bar -->
                <div class="mt-2 space-y-1">
                    <div class="flex gap-1">
                        <div class="strength-bar flex-1 bg-gray-200" id="bar1"></div>
                        <div class="strength-bar flex-1 bg-gray-200" id="bar2"></div>
                        <div class="strength-bar flex-1 bg-gray-200" id="bar3"></div>
                        <div class="strength-bar flex-1 bg-gray-200" id="bar4"></div>
                    </div>
                    <p class="text-xs text-gray-400" id="strength-text"></p>
                </div>
            </div>

            <!-- Confirm Password -->
            <div>
                <label class="block text-xs font-semibold text-gray-600 uppercase mb-2">Confirm Password</label>
                <input type="password" name="confirmPassword" id="confirmPassword" required
                       class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none transition"
                       placeholder="Repeat password">
                <p class="text-red-500 text-xs mt-1 hidden" id="confirm-error"></p>
            </div>

            <button type="submit"
                    class="w-full bg-scentCharcoal text-white py-3 mt-2 rounded-lg font-semibold hover:bg-scentAmber transition duration-300">
                Create Account
            </button>
        </form>

        <div class="flex items-center my-6">
            <div class="flex-1 h-px bg-gray-200"></div>
            <span class="px-4 text-xs text-gray-400 uppercase">Or</span>
            <div class="flex-1 h-px bg-gray-200"></div>
        </div>

        <a href="/auth/google"
           class="w-full flex items-center justify-center space-x-3 bg-white border border-gray-200 py-3 rounded-lg font-medium text-gray-700 hover:bg-gray-50 transition duration-300">
            <svg class="w-5 h-5" viewBox="0 0 24 24">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            <span>Sign up with Google</span>
        </a>

        <p class="text-center text-sm text-gray-500 mt-8">
            Already have an account? <a href="/auth/login" class="text-scentAmber font-semibold hover:underline">Log in</a>
        </p>
    </div>

    <script>
        const form = document.getElementById('signupForm');
        const fullname = document.getElementById('fullname');
        const email = document.getElementById('email');
        const password = document.getElementById('password');
        const confirmPassword = document.getElementById('confirmPassword');

        // Helper functions
        const showError = (id, msg) => {
            const el = document.getElementById(id);
            el.textContent = msg;
            el.classList.remove('hidden');
        };

        const clearError = (id) => {
            const el = document.getElementById(id);
            el.textContent = '';
            el.classList.add('hidden');
        };

        const setInputState = (input, isValid) => {
            input.classList.remove('input-error', 'input-success');
            input.classList.add(isValid ? 'input-success' : 'input-error');
        };

        // Password strength checker
        password.addEventListener('input', () => {
            const val = password.value;
            const bars = [document.getElementById('bar1'), document.getElementById('bar2'), document.getElementById('bar3'), document.getElementById('bar4')];
            const strengthText = document.getElementById('strength-text');

            let strength = 0;
            if (val.length >= 8) strength++;
            if (/[A-Z]/.test(val)) strength++;
            if (/[0-9]/.test(val)) strength++;
            if (/[^A-Za-z0-9]/.test(val)) strength++;

            const colors = ['#ef4444', '#f97316', '#eab308', '#22c55e'];
            const labels = ['Weak', 'Fair', 'Good', 'Strong'];

            bars.forEach((bar, i) => {
                bar.style.backgroundColor = i < strength ? colors[strength - 1] : '#e5e7eb';
            });

            strengthText.textContent = val.length > 0 ? labels[strength - 1] || '' : '';
            strengthText.style.color = strength > 0 ? colors[strength - 1] : '#9ca3af';
        });

        // Real-time confirm password check
        confirmPassword.addEventListener('input', () => {
            if (confirmPassword.value && confirmPassword.value !== password.value) {
                showError('confirm-error', 'Passwords do not match');
                setInputState(confirmPassword, false);
            } else if (confirmPassword.value) {
                clearError('confirm-error');
                setInputState(confirmPassword, true);
            }
        });

        // Real-time email validation
        email.addEventListener('blur', () => {
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(email.value)) {
                showError('email-error', 'Please enter a valid email');
                setInputState(email, false);
            } else {
                clearError('email-error');
                setInputState(email, true);
            }
        });

        // Real-time name validation
        fullname.addEventListener('blur', () => {
            if (fullname.value.trim().length < 2) {
                showError('fullname-error', 'Name must be at least 2 characters');
                setInputState(fullname, false);
            } else {
                clearError('fullname-error');
                setInputState(fullname, true);
            }
        });

        // Form submit validation
        form.addEventListener('submit', (e) => {
            let valid = true;

            if (fullname.value.trim().length < 2) {
                showError('fullname-error', 'Name must be at least 2 characters');
                setInputState(fullname, false);
                valid = false;
            }

            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(email.value)) {
                showError('email-error', 'Please enter a valid email');
                setInputState(email, false);
                valid = false;
            }

            if (password.value.length < 8) {
                showError('password-error', 'Password must be at least 8 characters');
                setInputState(password, false);
                valid = false;
            }


            if (confirmPassword.value !== password.value) {
                showError('confirm-error', 'Passwords do not match');
                setInputState(confirmPassword, false);
                valid = false;
            }

            if (!valid) e.preventDefault();
        });
    </script>

</body>
</html>