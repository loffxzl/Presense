    <!-- JS ENGINE 1: Blowing Flower Petals -->
    <script>
        const canvas = document.getElementById('scent-petals');
        const ctx = canvas.getContext('2d');
        let width = canvas.width = window.innerWidth;
        let height = canvas.height = window.innerHeight;
        window.addEventListener('resize', () => { width = canvas.width = window.innerWidth; height = canvas.height = window.innerHeight; });
        const petals = [];
        class Petal {
            constructor() { this.reset(); this.y = Math.random() * height; }
            reset() {
                this.x = Math.random() * width; this.y = -20; this.size = Math.random() * 5 + 4;
                this.speedY = Math.random() * 0.8 + 0.4; this.speedX = Math.random() * 1.2 - 0.4;
                this.opacity = Math.random() * 0.4 + 0.15; this.flip = Math.random(); this.flipSpeed = Math.random() * 0.02 + 0.01;
                this.color = Math.random() > 0.5 ? '212, 175, 55' : '112, 83, 53';
            }
            update(scrollImpact) {
                this.y += this.speedY + (scrollImpact * 0.2); this.x += this.speedX + (scrollImpact * 0.9); this.flip += this.flipSpeed;
                if (this.y > height || this.x > width || this.x < -20) this.reset();
            }
            draw() {
                ctx.save(); ctx.translate(this.x, this.y); ctx.rotate(this.flip); ctx.scale(Math.sin(this.flip), 1); ctx.beginPath();
                ctx.fillStyle = `rgba(${this.color}, ${this.opacity})`;
                for (let i = 0; i < 4; i++) { ctx.rotate(Math.PI / 2); ctx.moveTo(0, 0); ctx.quadraticCurveTo(this.size, this.size / 2, this.size, 0); ctx.quadraticCurveTo(this.size, -this.size / 2, 0, 0); }
                ctx.fill(); ctx.restore();
            }
        }
        for (let i = 0; i < 20; i++) petals.push(new Petal());
        let lastScrollY = window.scrollY, scrollVelocity = 0;
        window.addEventListener('scroll', () => { let currentScrollY = window.scrollY; scrollVelocity = Math.abs(currentScrollY - lastScrollY); lastScrollY = currentScrollY; });
        function renderLoop() { ctx.clearRect(0, 0, width, height); scrollVelocity *= 0.94; if (scrollVelocity < 0.05) scrollVelocity = 0; petals.forEach(p => { p.update(scrollVelocity); p.draw(); }); requestAnimationFrame(renderLoop); }
        renderLoop();
    </script>

    <!-- JS ENGINE 2: Automatic Banner Carousel -->
    <script>
        let currentSlideIndex = 0;
        const slides = document.querySelectorAll('.promo-slide');
        const dots = document.querySelectorAll('.slide-dot');
        let sliderInterval;
        function showSlide(index) {
            currentSlideIndex = index;
            slides.forEach((slide, i) => {
                if (i === index) {
                    slide.classList.remove('opacity-0', 'pointer-events-none', 'z-0'); slide.classList.add('opacity-100', 'z-10');
                    dots[i].classList.remove('opacity-40'); dots[i].classList.add('opacity-100');
                } else {
                    slide.classList.remove('opacity-100', 'z-10'); slide.classList.add('opacity-0', 'pointer-events-none', 'z-0');
                    dots[i].classList.remove('opacity-100'); dots[i].classList.add('opacity-40');
                }
            });
            clearInterval(sliderInterval); startAutoCycle();
        }
        function startAutoCycle() { sliderInterval = setInterval(() => { let nextSlide = (currentSlideIndex + 1) % slides.length; showSlide(nextSlide); }, 6000); }
        startAutoCycle();
    </script>

    <!-- JS ENGINE 3: 5-Card Shuffle Controller -->
    <script>
        const cards = document.querySelectorAll('.shuffle-card');
        const deckContainer = document.getElementById('interactive-deck');
        
        let cardOrder = [0, 1, 2, 3, 4];
        let shuffleInterval;
        let isShuffling = false;

        const stackStates = [
            { transform: 'translate(0px, 0px) scale(1) rotate(0deg)', zIndex: '50', opacity: '1' },          
            { transform: 'translate(16px, -16px) scale(0.96) rotate(2deg)', zIndex: '40', opacity: '0.90' }, 
            { transform: 'translate(32px, -32px) scale(0.92) rotate(4deg)', zIndex: '30', opacity: '0.75' }, 
            { transform: 'translate(-16px, 16px) scale(0.88) rotate(-2deg)', zIndex: '20', opacity: '0.55' },
            { transform: 'translate(-32px, 32px) scale(0.84) rotate(-4deg)', zIndex: '10', opacity: '0.35' } 
        ];

        function executeCardShuffle() {
            if (isShuffling || cards.length < 5) return; 
            isShuffling = true;

            const frontCardIndex = cardOrder[0];

            cards[frontCardIndex].style.transform = 'translate(-135%, 45px) scale(0.92) rotate(-16deg)';
            cards[frontCardIndex].style.opacity = '0';

            for (let i = 1; i < 5; i++) {
                const targetState = stackStates[i - 1];
                cards[cardOrder[i]].style.transform = targetState.transform;
                cards[cardOrder[i]].style.zIndex = targetState.zIndex;
                cards[cardOrder[i]].style.opacity = targetState.opacity;
            }

            setTimeout(() => {
                const baseState = stackStates[4];
                cards[frontCardIndex].style.zIndex = baseState.zIndex;
                cards[frontCardIndex].style.transform = baseState.transform;
                cards[frontCardIndex].style.opacity = baseState.opacity;

                cardOrder.push(cardOrder.shift());
                isShuffling = false;
            }, 450);
        }

        function startAutoShuffleTimer() { shuffleInterval = setInterval(executeCardShuffle, 4000); }

        if(deckContainer) {
            deckContainer.addEventListener('click', (e) => {
                e.preventDefault();
                clearInterval(shuffleInterval);
                executeCardShuffle();
                startAutoShuffleTimer();
            });
        }
        startAutoShuffleTimer();
    </script>

    <!-- Poetic Interlude Cycler -->
    <script>
        const stanzas = document.querySelectorAll('.poem-stanza');
        let currentStanza = 0;

        function cyclePoem() {
            let nextStanza = (currentStanza + 1) % stanzas.length;
            
            stanzas[currentStanza].classList.remove('opacity-100', 'z-10');
            stanzas[currentStanza].classList.add('opacity-0', 'pointer-events-none', 'z-0');
            
            stanzas[nextStanza].classList.remove('opacity-0', 'pointer-events-none', 'z-0');
            stanzas[nextStanza].classList.add('opacity-100', 'z-10');
            
            currentStanza = nextStanza;
        }


        if(stanzas.length > 0) {
            setInterval(cyclePoem, 8500);
        }
    </script>
