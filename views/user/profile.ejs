<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Presense</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        :root {
            --cream: #FDFBF7;
            --amber: #D4AF37;
            --charcoal: #1A1A1A;
            --hairline: #ECE7DC;
        }
        .bg-scentCream    { background-color: var(--cream); }
        .bg-scentCharcoal { background-color: var(--charcoal); }
        .bg-scentAmber    { background-color: var(--amber); }
        .text-scentAmber  { color: var(--amber); }
        .text-scentCharcoal { color: var(--charcoal); }
        .border-scentAmber { border-color: var(--amber); }
        .font-serif { font-family: Georgia, Cambria, "Times New Roman", Times, serif; }
        .input-error   { border-color: #ef4444 !important; }
        .input-success { border-color: #22c55e !important; }

        .icon-svg { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 1.75; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }

        /* Sidebar nav */
        .side-link {
            display: flex; align-items: center; gap: 12px;
            padding: 12px 16px; border-radius: 10px;
            font-size: 14px; color: #6b6b6b;
            border-left: 3px solid transparent;
            transition: background .15s ease, color .15s ease, border-color .15s ease;
        }
        .side-link:hover { background: #F6F2E8; color: var(--charcoal); }
        .side-link.active {
            background: #F6F2E8; color: var(--charcoal);
            border-left: 3px solid var(--amber); font-weight: 600;
        }
        .side-link.danger:hover { background: #FEF2F2; color: #ef4444; }

        /* Account settings rows */
        .setting-row {
            display: flex; align-items: center; gap: 16px;
            padding: 20px 24px; cursor: pointer;
            transition: background .15s ease;
        }
        .setting-row:hover { background: #FBF9F3; }
        .setting-row .chev { transition: transform .2s ease; color: #9a9a9a; }
        .setting-row.open .chev { transform: rotate(90deg); }
        .setting-icon {
            width: 40px; height: 40px; border-radius: 9999px;
            background: #F6F2E8; display: flex; align-items: center;
            justify-content: center; flex-shrink: 0; color: var(--charcoal);
        }
        .settings-panel {
            max-height: 0; overflow: hidden;
            transition: max-height .25s ease;
            border-top: 1px solid var(--hairline);
        }
        .settings-panel.open { max-height: 900px; }
        .settings-panel-inner { padding: 24px; }

        #editPanel { max-height: 0; overflow: hidden; transition: max-height .25s ease; }
        #editPanel.open { max-height: 500px; margin-top: 20px; }

        .badge { display: inline-flex; align-items: center; gap: 4px; }
        .pass-toggle { display: flex; align-items: center; justify-content: center; }

        /* Avatar: hard-coded so layout can't collapse if Tailwind JIT
           doesn't pick up utility classes from .ejs files */
        .avatar-circle {
            width: 80px;
            height: 80px;
            min-width: 80px;
            min-height: 80px;
            border-radius: 9999px;
            border: 4px solid var(--amber);
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }
        .avatar-circle img { width: 100%; height: 100%; object-fit: cover; }
        .profile-header { display: flex; align-items: center; gap: 24px; flex-wrap: wrap; }
        .profile-header-info { min-width: 0; }
    </style>
</head>
<body class="bg-scentCream min-h-screen">

    <!-- Navbar -->
    <nav class="bg-white border-b border-gray-200 px-6 py-4 sticky top-0 z-50">
        <div class="max-w-6xl mx-auto flex justify-between items-center">
            <a href="/" class="text-2xl font-serif font-bold tracking-widest uppercase text-scentCharcoal">Presense</a>
            <div class="flex items-center gap-6">
                <a href="/home" class="text-sm text-gray-600 hover:text-scentAmber transition">Home</a>
                <a href="/auth/logout" class="text-sm text-gray-600 hover:text-red-500 transition">Logout</a>
            </div>
        </div>
    </nav>

    <div class="max-w-6xl mx-auto px-6 py-10 grid gap-8" style="grid-template-columns: 260px 1fr;">

        <!-- Left Sidebar -->
        <aside>
            <nav class="space-y-1 sticky top-24">
                <a href="/profile" class="side-link active">
                    <svg class="icon-svg" viewBox="0 0 24 24"><path d="M20 21a8 8 0 0 0-16 0"/><circle cx="12" cy="7" r="4"/></svg>
                    Profile
                </a>
                <a href="/orders" class="side-link">
                    <svg class="icon-svg" viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                    My Orders
                </a>
                <a href="/wallet" class="side-link">
                    <svg class="icon-svg" viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2"/><path d="M2 10h20"/><path d="M6 15h4"/></svg>
                    Wallet
                </a>
                <a href="/profile/addresses" class="side-link">
                    <svg class="icon-svg" viewBox="0 0 24 24"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                    Address
                </a>
                <a href="/reviews" class="side-link">
                    <svg class="icon-svg" viewBox="0 0 24 24"><path d="M12 2 9.2 8.6 2 9.2l5.5 4.7L5.8 21 12 17.3 18.2 21l-1.7-7.1L22 9.2l-7.2-.6Z"/></svg>
                    Review History
                </a>
                <div class="border-t border-gray-200 my-3"></div>
                <a href="/auth/logout" class="side-link danger" style="color:#ef4444;">
                    <svg class="icon-svg" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><path d="M16 17l5-5-5-5"/><path d="M21 12H9"/></svg>
                    Sign Out
                </a>
            </nav>
        </aside>

        <!-- Right Content -->
        <main>

            <h1 class="font-serif text-3xl font-bold text-scentCharcoal">My Profile</h1>
            <p class="text-gray-400 text-sm mt-1 mb-6">Manage your personal information and security settings.</p>

            <!-- Success/Error Alert -->
            <% if (typeof success !== 'undefined' && success) { %>
                <div class="bg-green-50 border border-green-200 text-green-700 px-4 py-3 rounded-lg mb-6 text-sm flex items-center gap-2">
                    <svg class="icon-svg" style="width:16px;height:16px;" viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg>
                    <%= success %>
                </div>
            <% } %>
            <% if (typeof error !== 'undefined' && error) { %>
                <div class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded-lg mb-6 text-sm flex items-center gap-2">
                    <svg class="icon-svg" style="width:16px;height:16px;" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 8v5"/><path d="M12 16h.01"/></svg>
                    <%= error %>
                </div>
            <% } %>

            <!-- Profile Summary Card -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
                <div class="flex items-start justify-between gap-6 flex-wrap">
                    <div class="profile-header">
                        <% if (user.avatarUrl) { %>
                            <div class="avatar-circle">
                                <img src="<%= user.avatarUrl %>" alt="Avatar">
                            </div>
                        <% } else { %>
                            <div class="avatar-circle bg-scentCharcoal">
                                <span class="text-2xl font-bold text-white font-serif">
                                    <%= user.name.charAt(0).toUpperCase() %>
                                </span>
                            </div>
                        <% } %>

                        <div class="profile-header-info">
                            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Full Name</p>
                            <p class="font-serif text-xl font-bold text-scentCharcoal mb-3"><%= user.name %></p>

                            <div class="flex flex-wrap gap-x-10 gap-y-3">
                                <div>
                                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Email</p>
                                    <p class="text-sm text-scentCharcoal flex items-center gap-2">
                                        <%= user.email %>
                                        <% if (user.isEmailVerified) { %>
                                            <span class="badge text-xs bg-green-50 text-green-600 px-2 py-0.5 rounded-full font-medium">
                                                <svg class="icon-svg" style="width:12px;height:12px;" viewBox="0 0 24 24"><path d="M20 6 9 17l-5-5"/></svg>
                                                Verified
                                            </span>
                                        <% } else { %>
                                            <span class="badge text-xs bg-red-50 text-red-500 px-2 py-0.5 rounded-full font-medium">
                                                <svg class="icon-svg" style="width:12px;height:12px;" viewBox="0 0 24 24"><path d="M18 6 6 18"/><path d="M6 6l12 12"/></svg>
                                                Not Verified
                                            </span>
                                        <% } %>
                                    </p>
                                </div>
                                <div>
                                    <p class="text-xs font-semibold text-gray-400 uppercase tracking-wide mb-1">Phone</p>
                                    <p class="text-sm text-scentCharcoal"><%= user.phone || '—' %></p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <button type="button" onclick="toggleEdit()"
                            class="bg-scentCharcoal text-white px-6 py-2.5 rounded-lg text-xs font-semibold uppercase tracking-wide hover:bg-scentAmber transition duration-300 whitespace-nowrap flex items-center gap-2">
                        <svg class="icon-svg" style="width:14px;height:14px;" viewBox="0 0 24 24"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
                        Edit Profile
                    </button>
                </div>

                <!-- Edit Profile Panel (hidden by default) -->
                <div id="editPanel">
                    <div class="border-t border-gray-100 pt-6">
                        <form action="/profile/update" method="POST" id="profileForm" novalidate>
                            <div class="grid sm:grid-cols-2 gap-5">
                                <div>
                                    <label class="block text-xs font-semibold text-gray-600 uppercase mb-2">Full Name</label>
                                    <input type="text" name="name" id="name"
                                           value="<%= user.name %>"
                                           class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none transition text-sm">
                                    <p class="text-red-500 text-xs mt-1 hidden" id="name-error"></p>
                                </div>

                                <div>
                                    <label class="block text-xs font-semibold text-gray-600 uppercase mb-2">Phone Number</label>
                                    <input type="tel" name="phone" id="phone"
                                           value="<%= user.phone || '' %>"
                                           placeholder="+91 9876543210"
                                           class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none transition text-sm">
                                    <p class="text-red-500 text-xs mt-1 hidden" id="phone-error"></p>
                                </div>
                            </div>

                            <div class="pt-5 flex gap-3">
                                <button type="submit"
                                        class="bg-scentCharcoal text-white px-8 py-3 rounded-lg text-sm font-semibold hover:bg-scentAmber transition duration-300">
                                    Save Changes
                                </button>
                                <button type="button" onclick="toggleEdit()"
                                        class="px-8 py-3 rounded-lg text-sm font-semibold border border-gray-200 text-gray-500 hover:bg-gray-50 transition">
                                    Cancel
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Account Settings -->
            <h2 class="font-serif text-xl font-bold text-scentCharcoal mt-10 mb-4">Account Settings</h2>

            <% if (user.passwordHash !== 'google-oauth') { %>
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden mb-4">
                <div class="setting-row" id="row-password" onclick="toggleSetting('password')">
                    <div class="setting-icon">
                        <svg class="icon-svg" viewBox="0 0 24 24"><rect x="4" y="10" width="16" height="11" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>
                    </div>
                    <div class="flex-1">
                        <p class="text-sm font-semibold text-scentCharcoal">Change Password</p>
                        <p class="text-xs text-gray-400 mt-0.5">Update your credentials to maintain security.</p>
                    </div>
                    <svg class="icon-svg chev" viewBox="0 0 24 24"><path d="m9 18 6-6-6-6"/></svg>
                </div>
                <div class="settings-panel" id="panel-password">
                    <div class="settings-panel-inner">
                        <form action="/profile/change-password" method="POST" id="passwordForm" novalidate>
                            <div class="space-y-5">

                                <div>
                                    <label class="block text-xs font-semibold text-gray-600 uppercase mb-2">Current Password</label>
                                    <div class="relative">
                                        <input type="password" name="currentPassword" id="currentPassword"
                                               class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none transition text-sm"
                                               placeholder="Enter current password">
                                        <button type="button" onclick="togglePass('currentPassword', this)"
                                                class="pass-toggle absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                                            <svg class="icon-svg" viewBox="0 0 24 24" data-eye-open><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                                        </button>
                                    </div>
                                    <p class="text-red-500 text-xs mt-1 hidden" id="current-error"></p>
                                </div>

                                <div>
                                    <label class="block text-xs font-semibold text-gray-600 uppercase mb-2">New Password</label>
                                    <div class="relative">
                                        <input type="password" name="newPassword" id="newPassword"
                                               class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none transition text-sm"
                                               placeholder="Min 8 characters">
                                        <button type="button" onclick="togglePass('newPassword', this)"
                                                class="pass-toggle absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                                            <svg class="icon-svg" viewBox="0 0 24 24" data-eye-open><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                                        </button>
                                    </div>
                                    <p class="text-red-500 text-xs mt-1 hidden" id="new-error"></p>
                                </div>

                                <div>
                                    <label class="block text-xs font-semibold text-gray-600 uppercase mb-2">Confirm New Password</label>
                                    <div class="relative">
                                        <input type="password" name="confirmNewPassword" id="confirmNewPassword"
                                               class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none transition text-sm"
                                               placeholder="Repeat new password">
                                        <button type="button" onclick="togglePass('confirmNewPassword', this)"
                                                class="pass-toggle absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
                                            <svg class="icon-svg" viewBox="0 0 24 24" data-eye-open><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                                        </button>
                                    </div>
                                    <p class="text-red-500 text-xs mt-1 hidden" id="confirm-new-error"></p>
                                </div>

                                <div class="pt-2">
                                    <button type="submit"
                                            class="bg-scentCharcoal text-white px-8 py-3 rounded-lg text-sm font-semibold hover:bg-scentAmber transition duration-300">
                                        Update Password
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
            <% } %>

        </main>
    </div>

    <script>
        // Eye / eye-off icon paths
        const EYE_OPEN = '<path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7Z"/><circle cx="12" cy="12" r="3"/>';
        const EYE_CLOSED = '<path d="M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 7 11 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.53 13.53 0 0 0 1 11s4 7 11 7a9.26 9.26 0 0 0 5.39-1.61"/><path d="m2 2 20 20"/><path d="M14.12 14.12a3 3 0 1 1-4.24-4.24"/>';

        // Edit profile toggle
        function toggleEdit() {
            document.getElementById('editPanel').classList.toggle('open');
        }

        // Account settings row toggle (accordion-style)
        function toggleSetting(name) {
            const panel = document.getElementById(`panel-${name}`);
            const row = document.getElementById(`row-${name}`);
            panel.classList.toggle('open');
            row.classList.toggle('open');
        }

        // Toggle password visibility
        function togglePass(id, btn) {
            const input = document.getElementById(id);
            const svg = btn.querySelector('svg');
            const isHidden = input.type === 'password';
            input.type = isHidden ? 'text' : 'password';
            svg.innerHTML = isHidden ? EYE_CLOSED : EYE_OPEN;
        }

        // Profile form validation
        document.getElementById('profileForm').addEventListener('submit', (e) => {
            let valid = true;
            const name = document.getElementById('name');
            const phone = document.getElementById('phone');

            if (name.value.trim().length < 2) {
                document.getElementById('name-error').textContent = 'Name must be at least 2 characters';
                document.getElementById('name-error').classList.remove('hidden');
                name.classList.add('input-error');
                valid = false;
            } else {
                document.getElementById('name-error').classList.add('hidden');
                name.classList.remove('input-error');
            }

            if (phone.value && !/^\d{10}$/.test(phone.value)) {
                document.getElementById('phone-error').textContent = 'Phone number must be exactly 10 digits';
                document.getElementById('phone-error').classList.remove('hidden');
                phone.classList.add('input-error');
                valid = false;
            } else {
                document.getElementById('phone-error').classList.add('hidden');
                phone.classList.remove('input-error');
            }

            if (!valid) e.preventDefault();
        });

        // Password form validation
        document.getElementById('passwordForm')?.addEventListener('submit', (e) => {
            let valid = true;
            const current = document.getElementById('currentPassword');
            const newPass = document.getElementById('newPassword');
            const confirm = document.getElementById('confirmNewPassword');

            if (!current.value) {
                document.getElementById('current-error').textContent = 'Current password is required';
                document.getElementById('current-error').classList.remove('hidden');
                valid = false;
            } else {
                document.getElementById('current-error').classList.add('hidden');
            }

            if (newPass.value.length < 8) {
                document.getElementById('new-error').textContent = 'Password must be at least 8 characters';
                document.getElementById('new-error').classList.remove('hidden');
                valid = false;
            } else {
                document.getElementById('new-error').classList.add('hidden');
            }

            if (confirm.value !== newPass.value) {
                document.getElementById('confirm-new-error').textContent = 'Passwords do not match';
                document.getElementById('confirm-new-error').classList.remove('hidden');
                valid = false;
            } else {
                document.getElementById('confirm-new-error').classList.add('hidden');
            }

            if (!valid) e.preventDefault();
        });

        // If password change failed server-side, auto-open that panel
        <% if (typeof error !== 'undefined' && error && user.passwordHash !== 'google-oauth') { %>
            toggleSetting('password');
        <% } %>
    </script>

</body>
</html>
