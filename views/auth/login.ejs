<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | Presense</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/tailwindcss/2.2.19/tailwind.min.css">

    <style>
        :root {
            --cream:    #FDFBF7;
            --amber:    #D4AF37;
            --charcoal: #1A1A1A;
        }
        .bg-scentCream    { background-color: var(--cream); }
        .bg-scentAmber    { background-color: var(--amber); }
        .bg-scentCharcoal { background-color: var(--charcoal); }
        .text-scentAmber    { color: var(--amber); }
        .text-scentCharcoal { color: var(--charcoal); }
        .border-scentAmber { border-color: var(--amber); }
        .hover\:bg-scentAmber:hover { background-color: var(--amber); }
        .focus\:border-scentAmber:focus { border-color: var(--amber); }
        .font-serif { font-family: Georgia, Cambria, "Times New Roman", Times, serif; }
    </style>
</head>
<body class="bg-scentCream min-h-screen flex items-center justify-center p-6">

    <div class="w-full max-w-md bg-white p-8 rounded-2xl shadow-xl border border-gray-100">
        <div class="text-center mb-8">
            <a href="/" class="text-3xl font-serif font-bold text-scentCharcoal tracking-widest uppercase">Presense</a>
            <p class="text-gray-500 text-sm mt-2">Welcome back, connoisseur.</p>
        </div>

        <form action="/auth/login" method="POST" class="space-y-5">

            <% if (error) { %>
                <div class="bg-red-50 border border-red-200 text-red-600 text-sm px-4 py-3 rounded-lg">
                    <%= error %>
                </div>
            <% } %>

            <div>
                <label class="block text-xs font-semibold text-gray-600 uppercase mb-2">Email Address</label>
                <input type="email" name="email" required
                       class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:border-scentAmber transition">
            </div>
            <div>
                <label class="block text-xs font-semibold text-gray-600 uppercase mb-2">Password</label>
                <input type="password" name="password" required
                       class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg focus:outline-none focus:border-scentAmber transition">
            </div>

            <button type="submit"
                    class="w-full bg-scentCharcoal text-white py-3 rounded-lg font-semibold hover:bg-scentAmber transition duration-300">
                Log In
            </button>
        </form>

        <div class="flex items-center my-6">
            <div class="flex-1 h-px bg-gray-200"></div>
            <span class="px-4 text-xs text-gray-400 uppercase">Or</span>
            <div class="flex-1 h-px bg-gray-200"></div>
        </div>

        <a href="/auth/google"
           class="w-full flex items-center justify-center space-x-3 bg-white border border-gray-200 py-3 rounded-lg font-medium text-gray-700 hover:bg-gray-50 transition duration-300">
            <svg class="w-5 h-5" viewBox="0 0 24 24">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            <span>Continue with Google</span>
        </a>

        <p class="text-center text-sm text-gray-500 mt-8">
            Don't have an account? <a href="/signup" class="text-scentAmber font-semibold hover:underline">Sign up</a>
        </p>
    </div>
</body>
</html>