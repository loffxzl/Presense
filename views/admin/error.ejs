<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= statusCode %> | Presense Admin</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .font-serif { font-family: Georgia, serif; }
    </style>
</head>
<body class="bg-gray-100 min-h-screen flex items-center justify-center">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-12 text-center max-w-md">
        <h1 class="font-serif text-6xl font-bold text-gray-900 mb-4"><%= statusCode %></h1>
        <p class="text-gray-500 text-sm mb-6"><%= message %></p>
        <a href="/admin/users" class="bg-gray-900 text-white px-6 py-2.5 rounded-lg text-sm font-semibold hover:bg-gray-700 transition">
            Back to Dashboard
        </a>
    </div>
</body>
</html>