<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Presense</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        :root {
            --cream: #FDFBF7;
            --amber: #D4AF37;
            --charcoal: #1A1A1A;
        }
        .bg-scentCream { background-color: var(--cream); }
        .bg-scentCharcoal { background-color: var(--charcoal); }
        .text-scentAmber { color: var(--amber); }
        .hover\:bg-scentAmber:hover { background-color: var(--amber); }
        .font-serif { font-family: Georgia, Cambria, "Times New Roman", Times, serif; }
    </style>
</head>
<body class="bg-scentCream min-h-screen flex items-center justify-center p-6">

    <div class="w-full max-w-md bg-white p-8 rounded-2xl shadow-xl border border-gray-100">
        <div class="text-center mb-8">
            <a href="/" class="text-3xl font-serif font-bold text-gray-900 tracking-widest uppercase">Presense</a>
            <p class="text-gray-500 text-sm mt-2">Enter the code sent to</p>
            <p class="text-gray-800 font-semibold text-sm mt-1"><%= email %></p>
        </div>

        <% if (error) { %>
            <div class="bg-red-50 border border-red-200 text-red-600 text-sm px-4 py-3 rounded-lg mb-4">
                <%= error %>
            </div>
        <% } %>

        <% if (message) { %>
            <div class="bg-green-50 border border-green-200 text-green-600 text-sm px-4 py-3 rounded-lg mb-4">
                <%= message %>
            </div>
        <% } %>

        <!-- OTP Form -->
        <form action="/auth/verify-otp" method="POST" class="space-y-5">
            <div>
                <label class="block text-xs font-semibold text-gray-600 uppercase mb-2">Verification Code</label>
                <input
                    type="text"
                    name="otp"
                    maxlength="6"
                    placeholder="Enter 6-digit code"
                    required
                    class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-lg text-center text-2xl font-bold tracking-widest focus:outline-none focus:border-yellow-500 transition"
                />
            </div>

            <button type="submit"
                class="w-full bg-scentCharcoal text-white py-3 rounded-lg font-semibold hover:bg-scentAmber transition duration-300">
                Verify
            </button>
        </form>

        <!-- Timer and Resend -->
        <div class="text-center mt-6">
            <p class="text-sm text-gray-500">
                Code expires in <span id="timer" class="font-semibold text-scentAmber">10:00</span>
            </p>

            <form action="/auth/resend-otp" method="POST" class="mt-3">
                <button
                    type="submit"
                    id="resendBtn"
                    disabled
                    class="text-sm font-semibold text-gray-400 cursor-not-allowed transition"
                    id="resendBtn">
                    Resend OTP
                </button>
            </form>
        </div>

        <p class="text-center text-sm text-gray-500 mt-6">
            Wrong email? <a href="/auth/signup" class="text-scentAmber font-semibold hover:underline">Go back</a>
        </p>
    </div>

    <script>
        // OTP Timer
        let seconds = 60; 
        const timerEl = document.getElementById('timer');
        const resendBtn = document.getElementById('resendBtn');

        const interval = setInterval(() => {
            seconds--;
            const mins = Math.floor(seconds / 60);
            const secs = seconds % 60;
            timerEl.textContent = `${mins}:${secs.toString().padStart(2, '0')}`;

            if (seconds <= 0) {
                clearInterval(interval);
                timerEl.textContent = '0:00';
                timerEl.classList.add('text-red-500');

                // Enable resend button
                resendBtn.disabled = false;
                resendBtn.classList.remove('text-gray-400', 'cursor-not-allowed');
                resendBtn.classList.add('text-scentAmber', 'cursor-pointer', 'hover:underline');
            }
        }, 1000);
    </script>

</body>
</html>