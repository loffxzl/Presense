<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= statusCode %> | Presense</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        :root { --cream: #FDFBF7; --amber: #D4AF37; --charcoal: #1A1A1A; }
        .bg-scentCream { background-color: var(--cream); }
        .font-serif { font-family: Georgia, serif; }
        .text-scentAmber { color: var(--amber); }
    </style>
</head>
<body class="bg-scentCream min-h-screen flex items-center justify-center">
    <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-12 text-center max-w-md">
        <h1 class="font-serif text-6xl font-bold text-gray-900 mb-4"><%= statusCode %></h1>
        <p class="text-gray-500 text-sm mb-6"><%= message %></p>
        <a href="/" class="bg-gray-900 text-white px-6 py-2.5 rounded-lg text-sm font-semibold hover:text-scentAmber transition">
            Back to Home
        </a>
    </div>
</body>
</html>