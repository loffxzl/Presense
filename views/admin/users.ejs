<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Presense</title>

    <!-- ✅ CSP-safe: cdnjs Tailwind v2 -->
    <link rel="stylesheet" href="/css/style.css">

    <style>
        :root {
            --cream: #FDFBF7;
            --amber: #D4AF37;
            --charcoal: #1A1A1A;
        }
        .bg-scentCharcoal { background-color: var(--charcoal); }
        .text-scentAmber  { color: var(--amber); }
        .bg-scentAmber    { background-color: var(--amber); }
        .font-serif { font-family: Georgia, Cambria, "Times New Roman", Times, serif; }
    </style>
</head>
<body class="bg-gray-50 flex min-h-screen">

    <!-- Sidebar -->
    <aside class="w-64 bg-white border-r border-gray-200 flex flex-col justify-between p-4">
        <div>
            <div class="flex items-center gap-2 mb-8 p-2">
                <h1 class="font-serif font-bold text-xl tracking-widest uppercase">Presense</h1>
            </div>
            <nav class="space-y-2">
                <a href="#" class="block p-3 rounded-lg text-gray-600 hover:bg-gray-100">Dashboard</a>
                <a href="#" class="block p-3 rounded-lg text-gray-600 hover:bg-gray-100">Products</a>
                <a href="#" class="block p-3 rounded-lg text-gray-600 hover:bg-gray-100">Orders</a>
                <a href="/admin/users" class="block p-3 rounded-lg bg-gray-900 text-white font-medium">Customers</a>
                <a href="#" class="block p-3 rounded-lg text-gray-600 hover:bg-gray-100">Sales Report</a>
                <a href="#" class="block p-3 rounded-lg text-gray-600 hover:bg-gray-100">Coupon</a>
                <a href="#" class="block p-3 rounded-lg text-gray-600 hover:bg-gray-100">Category</a>
            </nav>
        </div>
        <div class="border-t pt-4">
            <div class="flex items-center gap-3 mb-4 p-2">
                <div class="bg-gray-200 rounded-full w-10 h-10 flex items-center justify-center font-bold text-sm">
                    <%= adminName.charAt(0).toUpperCase() %>
                </div>
                <div>
                    <p class="font-bold text-sm"><%= adminName %></p>
                    <p class="text-xs text-gray-500">Admin</p>
                </div>
            </div>
            <a href="/admin/logout" class="text-gray-500 text-sm flex items-center gap-2 hover:text-red-600">
                <span>⎋</span> Sign Out
            </a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 p-8">
        <h2 class="text-2xl font-bold mb-6">Customer Management</h2>

        <div class="bg-white p-6 rounded-xl border border-gray-200 shadow-sm">

            <!-- Search -->
            <form action="/admin/users" method="GET" class="flex gap-3 mb-6">
                <input
                    type="text"
                    name="search"
                    value="<%= search %>"
                    placeholder="Search by name or email..."
                    class="border p-2 rounded-lg flex-1 text-sm focus:outline-none focus:border-gray-400"
                />
                <button type="submit" class="bg-gray-900 text-white px-4 py-2 rounded-lg text-sm hover:bg-gray-700 transition">
                    Search
                </button>
                <% if (search) { %>
                    <a href="/admin/users" class="border px-4 py-2 rounded-lg text-sm text-gray-600 hover:bg-gray-100 transition">
                        Clear
                    </a>
                <% } %>
            </form>

            <!-- Table -->
            <table class="w-full text-sm text-left">
                <thead class="text-gray-500 border-b">
                    <tr>
                        <th class="p-3">#</th>
                        <th class="p-3">Name</th>
                        <th class="p-3">Email</th>
                        <th class="p-3">Status</th>
                        <th class="p-3">Joined</th>
                        <th class="p-3">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y">
                    <% if (users.length === 0) { %>
                        <tr>
                            <td colspan="6" class="text-center py-8 text-gray-400">No users found</td>
                        </tr>
                    <% } else { %>
                        <% users.forEach((user, index) => { %>
                            <tr class="hover:bg-gray-50">
                                <td class="p-3 text-gray-400">
                                    <%= (currentPage - 1) * 10 + index + 1 %>
                                </td>
                                <td class="p-3">
                                    <div class="flex items-center gap-3">
                                        <div class="bg-gray-200 rounded-full w-8 h-8 flex items-center justify-center font-bold text-xs">
                                            <%= user.name.charAt(0).toUpperCase() %>
                                        </div>
                                        <%= user.name %>
                                    </div>
                                </td>
                                <td class="p-3 text-gray-600"><%= user.email %></td>
                                <td class="p-3">
                                    <span class="px-2 py-1 rounded-full text-xs font-semibold
                                        <%= user.status === 'active' ? 'bg-green-50 text-green-600' : 'bg-red-50 text-red-600' %>">
                                        <%= user.status %>
                                    </span>
                                </td>
                                <td class="p-3 text-gray-400">
                                    <%= new Date(user.createdAt).toLocaleDateString('en-IN') %>
                                </td>
                                <td class="p-3">
                                    <button
                                        onclick="openModal('<%= user._id %>', '<%= user.name %>', '<%= user.status %>')"
                                        class="text-xs font-semibold px-3 py-1 rounded transition
                                            <%= user.status === 'active' ? 'text-red-600 hover:bg-red-50' : 'text-green-600 hover:bg-green-50' %>">
                                        <%= user.status === 'active' ? 'Block' : 'Unblock' %>
                                    </button>
                                </td>
                            </tr>
                        <% }) %>
                    <% } %>
                </tbody>
            </table>

            <!-- Total -->
            <p class="text-xs text-gray-400 mt-4">Total users: <%= totalUsers %></p>

            <!-- Pagination -->
            <% if (totalPages > 1) { %>
                <div class="mt-4 flex justify-end gap-2 text-sm">
                    <% if (currentPage > 1) { %>
                        <a href="/admin/users?page=<%= currentPage - 1 %>&search=<%= search %>"
                            class="border px-3 py-1 rounded hover:bg-gray-100">&lt;</a>
                    <% } %>

                    <% for (let i = 1; i <= totalPages; i++) { %>
                        <a href="/admin/users?page=<%= i %>&search=<%= search %>"
                            class="px-3 py-1 rounded transition
                                <%= i === currentPage ? 'bg-gray-900 text-white' : 'border hover:bg-gray-100' %>">
                            <%= i %>
                        </a>
                    <% } %>

                    <% if (currentPage < totalPages) { %>
                        <a href="/admin/users?page=<%= currentPage + 1 %>&search=<%= search %>"
                            class="border px-3 py-1 rounded hover:bg-gray-100">&gt;</a>
                    <% } %>
                </div>
            <% } %>

        </div>
    </main>

    <!-- Confirmation Modal -->
    <div id="confirmModal" class="fixed inset-0 flex items-center justify-center hidden z-50" style="background: rgba(0,0,0,0.5);">
        <div class="bg-white rounded-xl shadow-xl p-6 w-full max-w-sm">
            <h3 class="text-lg font-bold text-gray-800 mb-2" id="modalTitle">Confirm Action</h3>
            <p class="text-sm text-gray-500 mb-6" id="modalMessage">Are you sure?</p>
            <div class="flex gap-3 justify-end">
                <button
                    onclick="closeModal()"
                    class="px-4 py-2 text-sm rounded-lg border text-gray-600 hover:bg-gray-100 transition">
                    Cancel
                </button>
                <form id="modalForm" method="POST">
                    <input type="hidden" name="search" value="<%= search %>" />
                    <input type="hidden" name="page" value="<%= currentPage %>" />
                    <button
                        type="submit"
                        id="modalConfirmBtn"
                        class="px-4 py-2 text-sm rounded-lg text-white transition">
                        Confirm
                    </button>
                </form>
            </div>
        </div>
    </div>

    <script>
        
          window.addEventListener('pageshow', function (event) {
            if (event.persisted) {
                window.location.reload();
            }
        });

        function openModal(userId, userName, currentStatus) {
            const isBlocking = currentStatus === 'active';

            document.getElementById('modalTitle').textContent = isBlocking ? 'Block User' : 'Unblock User';
            document.getElementById('modalMessage').textContent =
                `Are you sure you want to ${isBlocking ? 'block' : 'unblock'} ${userName}?`;

            const confirmBtn = document.getElementById('modalConfirmBtn');
            confirmBtn.textContent = isBlocking ? 'Block' : 'Unblock';
            confirmBtn.style.backgroundColor = isBlocking ? '#dc2626' : '#16a34a';
            confirmBtn.onmouseover = () => confirmBtn.style.backgroundColor = isBlocking ? '#b91c1c' : '#15803d';
            confirmBtn.onmouseout  = () => confirmBtn.style.backgroundColor = isBlocking ? '#dc2626' : '#16a34a';

            document.getElementById('modalForm').action =
                `/admin/users/${userId}/toggle-status?_method=PATCH`;

            document.getElementById('confirmModal').classList.remove('hidden');
        }

        function closeModal() {
            document.getElementById('confirmModal').classList.add('hidden');
        }

        document.getElementById('confirmModal').addEventListener('click', function(e) {
            if (e.target === this) closeModal();
        });
    </script>

</body>
</html>
